{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "agent": {},
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_MCP_TOKEN}"
      },
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:LINEAR_MCP_TOKEN}"
      }
    }
  },
  "permission": {
    "bash(git commit*)": "ask",
    "bash(git push*)": "ask",
    "bash(git reflog*)": "ask",
    "bash(git reset*)": "ask"
  }
}
